# Rural Health AI Platform — Environment Variables
# Copy this file and fill in real values.
# See apps/web/.env.example and apps/api/.env.example for app-specific vars.

# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (for backend/API — never expose to client)
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── API ────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
PRESCRIPTION_OCR_ENGINE=trocr
PRESCRIPTION_OCR_MODEL_PATH=models/prescription_ocr_trocr_int8.onnx
PRESCRIPTION_OCR_MIN_CONFIDENCE=0.45
PRESCRIPTION_OCR_CLOUD_FALLBACK=false

# ─── QR Sharing ──────────────────────────────────────
# Secret for HMAC-SHA256 signing QR tokens (generate a strong random value)
QR_SIGNING_SECRET=change-me-to-a-random-secret
# Token expiry in seconds (default: 600 = 10 minutes)
QR_TTL_SECONDS=600

# ─── Feature flags ───────────────────────────────────
# Mount ABDM stub endpoints (development only — never enable in production)
ABDM_STUBS_ENABLED=true
